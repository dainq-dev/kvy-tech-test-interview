# Database
DATABASE_URL=postgresql://postgres:password@localhost:5433/doc_verification

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# File upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Backend URL (used by mock service for webhook callback)
BACKEND_URL=http://localhost:4000

# Mock service behavior
MOCK_MIN_DELAY_MS=3000
MOCK_MAX_DELAY_MS=8000
